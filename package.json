{
  "name": "strapi-plugin-comments",
  "version": "1.0.0",
  "description": "Plugin Strapi V5 — Système de commentaires avec modération, panneau admin, signalements, anti-injures, reCAPTCHA et rate limiting",
  "main": "./strapi-server.js",
  "types": "./dist/server/src/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    "./strapi-server": {
      "source": "./server/src/index.ts",
      "require": "./dist/server/src/index.js",
      "default": "./dist/server/src/index.js"
    },
    "./strapi-admin": {
      "source": "./admin/src/index.ts",
      "import": "./admin/src/index.ts",
      "require": "./admin/src/index.ts",
      "default": "./admin/src/index.ts"
    }
  },
  "files": [
    "dist",
    "admin",
    "strapi-server.js",
    "strapi-admin.js"
  ],
  "scripts": {
    "build": "tsc -p server/tsconfig.build.json",
    "watch": "tsc -p server/tsconfig.build.json --watch",
    "lint": "eslint server/src --ext .ts",
    "lint:fix": "eslint server/src --ext .ts --fix",
    "type-check": "tsc -p server/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "strapi",
    "plugin",
    "comments",
    "moderation",
    "recaptcha",
    "rate-limiting",
    "admin-panel",
    "reports"
  ],
  "author": "ISOMORPH <contact@isomorph.fr>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/isomorph-agency/strapi-plugin-comments.git"
  },
  "peerDependencies": {
    "@strapi/design-system": "^2.0.0",
    "@strapi/icons": "^2.0.0",
    "@strapi/strapi": "^5.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-intl": "^6.0.0",
    "react-router-dom": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "@strapi/design-system": {
      "optional": true
    },
    "@strapi/icons": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "react-intl": {
      "optional": true
    },
    "react-router-dom": {
      "optional": true
    }
  },
  "dependencies": {
    "leo-profanity": "^1.8.0",
    "xss": "^1.0.14",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@strapi/strapi": "^5.0.0",
    "@types/koa": "^2.15.0",
    "@types/leo-profanity": "^1.5.3",
    "@types/node": "^20.14.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  },
  "strapi": {
    "kind": "plugin",
    "name": "comments",
    "displayName": "Comments",
    "description": "Système de commentaires avec modération, panneau admin, signalements, anti-injures, reCAPTCHA V3 et rate limiting"
  },
  "overrides": {
    "styled-components": {
      "postcss": "^8.5.10"
    }
  }
}
